# ─── Supabase ────────────────────────────────────────────────────────────────
# These values differ per environment. NEVER share them across environments.
#
# All environments use Supabase cloud projects.
# DATABASE_URL must use the transaction pooler port 6543, NOT port 5432.
# MIGRATION_DATABASE_URL must use the direct connection port 5432.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Runtime app connection — always use port 6543 (transaction pooler)
DATABASE_URL=
# Migration-only connection — use direct connection port 5432 (more reliable for DDL)
# Format: postgresql://postgres:{password}@db.{ref}.supabase.co:5432/postgres?sslmode=require
MIGRATION_DATABASE_URL=

# ─── Tenant ──────────────────────────────────────────────────────────────────
# APRO_TENANT_ID is used ONLY for:
#   1. The charge generation cron endpoint (/api/v1/charges/generate)
#   2. Local seed scripts
#
# Route handlers must read tenant_id from the authenticated JWT (app_metadata),
# NOT from this env var.
#
# Local: use the seed UUID → 00000000-0000-0000-0000-000000000001
# Staging/Production: UUID of the tenant row in that environment's DB
APRO_TENANT_ID=

# ─── Charge generation endpoint ──────────────────────────────────────────────
# Random secret to protect the manual charge generation endpoint.
# Must match NEXT_PUBLIC_CHARGE_GENERATION_SECRET.
CHARGE_GENERATION_SECRET=
NEXT_PUBLIC_CHARGE_GENERATION_SECRET=

# ─── Twilio (WhatsApp notifications) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_TEMPLATE_REMINDER_SID=

# ─── Sentry (error monitoring) ───────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
